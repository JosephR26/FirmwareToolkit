#!/bin/sh
# Pre-commit hook for ESP32/embedded firmware projects
# This hook runs before each commit to validate code quality

echo "========================================"
echo "  Pre-Commit Validation"
echo "========================================"

# Check if this is a PlatformIO project
if [ ! -f "platformio.ini" ]; then
    echo "[INFO] Not a PlatformIO project - skipping firmware checks"
    exit 0
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the default environment from platformio.ini
DEFAULT_ENV=$(grep "default_envs" platformio.ini | cut -d'=' -f2 | tr -d ' ' | head -n1)
if [ -z "$DEFAULT_ENV" ]; then
    DEFAULT_ENV=$(grep "^\[env:" platformio.ini | head -n1 | sed 's/\[env://;s/\]//')
fi

echo "[INFO] Detected environment: $DEFAULT_ENV"

# Check 1: Verify code compiles
echo ""
echo "[CHECK 1/4] Verifying code compiles..."
if ! pio run --environment "$DEFAULT_ENV" --target clean > /dev/null 2>&1; then
    echo "${YELLOW}[WARNING] Clean failed${NC}"
fi

if pio run --environment "$DEFAULT_ENV" > /tmp/pio-build.log 2>&1; then
    echo "${GREEN}[PASS]${NC} Code compiles successfully"
else
    echo "${RED}[FAIL]${NC} Compilation failed!"
    cat /tmp/pio-build.log
    echo ""
    echo "${RED}Please fix compilation errors before committing${NC}"
    exit 1
fi

# Check 2: Check firmware size
echo ""
echo "[CHECK 2/4] Checking firmware size..."
SIZE_OUTPUT=$(pio run --environment "$DEFAULT_ENV" --target size 2>/dev/null)
echo "$SIZE_OUTPUT" | grep "RAM:"
echo "$SIZE_OUTPUT" | grep "Flash:"

# Extract RAM and Flash percentages (if available)
RAM_PCT=$(echo "$SIZE_OUTPUT" | grep -o "RAM:.*([0-9.]*%)" | grep -o "[0-9.]*%" | tr -d '%')
FLASH_PCT=$(echo "$SIZE_OUTPUT" | grep -o "Flash:.*([0-9.]*%)" | grep -o "[0-9.]*%" | tr -d '%')

if [ ! -z "$RAM_PCT" ] && [ $(echo "$RAM_PCT > 90" | bc -l 2>/dev/null || echo 0) -eq 1 ]; then
    echo "${RED}[WARNING]${NC} RAM usage > 90% - consider optimization"
fi

if [ ! -z "$FLASH_PCT" ] && [ $(echo "$FLASH_PCT > 90" | bc -l 2>/dev/null || echo 0) -eq 1 ]; then
    echo "${RED}[WARNING]${NC} Flash usage > 90% - consider optimization"
fi

echo "${GREEN}[PASS]${NC} Firmware size checked"

# Check 3: Look for common issues in staged files
echo ""
echo "[CHECK 3/4] Scanning for common issues..."
ISSUES_FOUND=0

# Get list of staged .cpp, .c, .h, .ino files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|c|h|ino)$')

if [ ! -z "$STAGED_FILES" ]; then
    # Check for Serial.print in production code (potential debug leftovers)
    if echo "$STAGED_FILES" | xargs grep -n "Serial\.print" > /dev/null 2>&1; then
        echo "${YELLOW}[WARNING]${NC} Found Serial.print statements - ensure debug code is intentional"
    fi

    # Check for delay() calls (blocking code)
    if echo "$STAGED_FILES" | xargs grep -n "delay(" > /dev/null 2>&1; then
        echo "${YELLOW}[WARNING]${NC} Found delay() calls - consider non-blocking alternatives"
    fi

    # Check for hardcoded WiFi credentials
    if echo "$STAGED_FILES" | xargs grep -i -n "password\s*=\s*\"" > /dev/null 2>&1; then
        echo "${RED}[FAIL]${NC} Possible hardcoded credentials detected!"
        echo "Please use environment variables or config files for sensitive data"
        ISSUES_FOUND=1
    fi

    # Check for TODO/FIXME comments
    TODO_COUNT=$(echo "$STAGED_FILES" | xargs grep -n "TODO\|FIXME" 2>/dev/null | wc -l)
    if [ "$TODO_COUNT" -gt 0 ]; then
        echo "${YELLOW}[INFO]${NC} Found $TODO_COUNT TODO/FIXME comments"
    fi
fi

if [ $ISSUES_FOUND -eq 0 ]; then
    echo "${GREEN}[PASS]${NC} Code quality checks passed"
else
    exit 1
fi

# Check 4: Check for large files
echo ""
echo "[CHECK 4/4] Checking for large files..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | while read file; do
    if [ -f "$file" ]; then
        size=$(wc -c < "$file")
        if [ $size -gt 1048576 ]; then  # 1MB
            echo "$file ($(echo "scale=2; $size/1048576" | bc)MB)"
        fi
    fi
done)

if [ ! -z "$LARGE_FILES" ]; then
    echo "${YELLOW}[WARNING]${NC} Large files detected:"
    echo "$LARGE_FILES"
    echo "Consider using Git LFS for binary assets"
else
    echo "${GREEN}[PASS]${NC} No large files detected"
fi

echo ""
echo "${GREEN}========================================"
echo "  Pre-Commit Validation PASSED"
echo "========================================${NC}"
exit 0
